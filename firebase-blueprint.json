{
  "entities": {
    "User": {
      "title": "User",
      "description": "Student or Admin user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "classLevel": { "type": "string" },
        "totalScore": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "email", "role", "createdAt", "updatedAt"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A quiz definition",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "classLevel": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "classLevel", "subject", "topic", "durationMinutes", "totalQuestions", "createdAt", "createdBy"]
    },
    "Question": {
      "title": "Question",
      "description": "A question inside a quiz",
      "type": "object",
      "properties": {
        "quizId": { "type": "string" },
        "text": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "correctOptionIndex": { "type": "number" },
        "explanation": { "type": "string" }
      },
      "required": ["quizId", "text", "options", "correctOptionIndex"]
    },
    "QuizAttempt": {
      "title": "QuizAttempt",
      "description": "Record of a student's attempt",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "quizId": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "completedAt": { "type": "string" }
      },
      "required": ["userId", "quizId", "score", "totalQuestions", "completedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin privilege record",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "grantedAt": { "type": "string" }
      },
      "required": ["email", "grantedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Student or Admin user profile"
    },
    "/quizzes/{quizId}": {
      "schema": { "$ref": "#/entities/Quiz" },
      "description": "A quiz definition"
    },
    "/quizzes/{quizId}/questions/{questionId}": {
      "schema": { "$ref": "#/entities/Question" },
      "description": "Questions inside a specific quiz"
    },
    "/quizAttempts/{attemptId}": {
      "schema": { "$ref": "#/entities/QuizAttempt" },
      "description": "Student quiz attempts"
    },
    "/admins/{userId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Admin privilege records"
    }
  }
}
